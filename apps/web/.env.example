# ─── LeetArena Web (apps/web) ────────────────────────────────────────────────
# Copy this to apps/web/.env and fill in your values.

# Supabase — from https://app.supabase.com → Project Settings → API
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# API — your Cloudflare Worker URL (or http://localhost:8787 for local dev)
PUBLIC_API_URL=https://leetarena-api.your-subdomain.workers.dev

# Optional UI feature toggles
# Allows showing extended-catalog variety mode in pack opening UI.
PUBLIC_ENABLE_EXTENDED_PACKS=false
